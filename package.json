{
  "name": "aryan-adhikari",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "npm run generate-config && npm run clean && tsc && npm run copy-assets",
    "generate-config": "node scripts/generate-config.js",
    "watch": "tsc --watch",
    "clean": "rm -rf public && mkdir -p public",
    "copy-assets": "cp index.html public/ && cp -r css public/ && cp -r img public/ && cp -r js public/ && cp CV_Aryan_Adhikari_Final.pdf public/",
    "serve": "python3 -m http.server 8000",
    "dev": "tsc",
    "migrate-data": "node migrate-data.js",
    "test": "playwright test",
    "test:local": "TEST_ENV=local playwright test",
    "test:production": "TEST_ENV=production playwright test",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.0.9",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.102.0",
    "dotenv": "^17.4.1"
  }
}
